# Copy to .env and fill in values if you need to override defaults.
# Most settings are in config/config.yaml — this file is for secrets only.

# Override the llama-api URL (default: http://host.docker.internal:8080)
# LLAMA_URL=http://host.docker.internal:8080

# OpenAI API key — required when llm.provider=openai (default config uses gpt-4o-mini)
OPENAI_API_KEY=

# Z.ai / GLM API key — required when llm.provider=glm (models.glm_5_1 uses this)
GLM_API_KEY=

# Anthropic API key — optional fallback when llm.provider=anthropic and no OAuth creds mounted
# ANTHROPIC_API_KEY=

# Exa web search API key (https://dashboard.exa.ai)
EXA_API_KEY=

# Notion integration token
NOTION_TOKEN=

# Discord bot tokens (create apps at https://discord.com/developers/applications)
DISCORD_TOKEN_WORKER=
DISCORD_TOKEN_CONFIG=

# Discord server (guild) ID — used for instant slash command sync
DISCORD_GUILD_ID=

# Comma-separated Discord channel IDs the bots listen in (optional — bots auto-create channels)
DISCORD_WORKER_CHANNELS=
DISCORD_CONFIG_CHANNELS=

# Comma-separated Discord user IDs allowed to interact with the bots.
# If set, messages from any other user are silently ignored.
# Leave empty to allow everyone (not recommended for private assistants).
DISCORD_ALLOWED_USER_IDS=

# ── Discord E2E scenario runner (optional, test only) ───────────────────────
# Channel id where `make e2e` will run scenarios. REQUIRED for scenarios to
# run — refuses to start without this to avoid polluting a real channel.
DISCORD_TEST_CHANNEL_ID=

# User id of the config bot (whoever DISCORD_TOKEN_CONFIG points at). When set,
# the worker bot stops ignoring messages from that specific bot author so the
# scenario runner can drive it. Leave blank outside of testing.
DISCORD_TEST_DRIVER_USER_ID=

# Set to 1 to enable !-prefixed text-command fallbacks (!mode, !model, !btw,
# !stop) in the worker bot. Needed for the E2E scenario runner since bots
# cannot invoke each other's slash commands. Off by default.
PHOEBE_ENABLE_TEXT_COMMANDS=

# E2E scenario messages: "1" keeps them in the channel so you can scroll back
# and inspect them (default), "0" deletes bot-authored messages after each
# scenario (CI-style).
PHOEBE_E2E_PERSIST_MESSAGES=1

# ── Dream digest mailer (optional; dream.email.enabled=true in config) ──────
# Cascade order: Gmail → generic SMTP → Discord fallback → disk note.
# Credentials are env-only; config.yaml carries addresses + toggles only.

# Gmail via SMTP_SSL :465. Use a Google App Password, not the account password.
# https://support.google.com/accounts/answer/185833
# DREAM_GMAIL_USER=phoebe.dream@gmail.com
# DREAM_GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Generic SMTP fallback. Port 465 uses SSL, anything else uses STARTTLS.
# DREAM_SMTP_HOST=
# DREAM_SMTP_PORT=465
# DREAM_SMTP_USER=
# DREAM_SMTP_PASS=
# DREAM_SMTP_FROM=
