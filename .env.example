# Copy to .env and fill in values if you need to override defaults.
# Most settings are in config/config.yaml — this file is for secrets only.

# Override the llama-api URL (default: http://host.docker.internal:8080)
# LLAMA_URL=http://host.docker.internal:8080

# Exa web search API key (https://dashboard.exa.ai)
EXA_API_KEY=

# Notion integration token
NOTION_TOKEN=

# Discord bot tokens (create apps at https://discord.com/developers/applications)
DISCORD_TOKEN_WORKER=
DISCORD_TOKEN_CONFIG=

# Discord server (guild) ID — used for instant slash command sync
DISCORD_GUILD_ID=

# Comma-separated Discord channel IDs the bots listen in (optional — bots auto-create channels)
DISCORD_WORKER_CHANNELS=
DISCORD_CONFIG_CHANNELS=

# Comma-separated Discord user IDs allowed to interact with the bots.
# If set, messages from any other user are silently ignored.
# Leave empty to allow everyone (not recommended for private assistants).
DISCORD_ALLOWED_USER_IDS=
